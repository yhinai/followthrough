# Followthrough defaults: authenticated devices with simple plaintext archive
# storage. Copy to .env and provide file-backed device/dashboard credentials.

FOLLOWTHROUGH_HOST=127.0.0.1
FOLLOWTHROUGH_PORT=18765
FOLLOWTHROUGH_PUBLIC_URL=https://followthrough.alhinai.dev

# Phone and dashboard authentication stays on by default.
FOLLOWTHROUGH_REQUIRE_AUTH=true

FOLLOWTHROUGH_DISCORD_TARGET=discord:1510104161612730378
FOLLOWTHROUGH_AUTO_SEND=false

# Optional partner integrations — leave empty to skip.
CONVEX_URL=
LINKUP_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
DODO_PAYMENTS_API_KEY=
DODO_PRODUCT_ID=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_KEY=
